<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Wameed" parent="Theme.AppCompat.Light.DarkActionBar" />

    <style name="Theme.Wameed.Splash" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/wameed_green</item>
        <item name="android:statusBarColor">@color/wameed_green_dark</item>
        <item name="android:navigationBarColor">@color/wameed_green</item>
        <!-- Suppress Android 12+ system splash screen icon -->
        <item name="android:windowSplashScreenBackground">@color/wameed_green</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <style name="Theme.AppCompat.Translucent" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Theme.Wameed.TransparentBottomSheet" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:colorPrimary">@color/wameed_green</item>
    </style>

</resources>